@model Messenger.Models.Entity.ChatMessage
@using Messenger.Models.Entity
@{
    var isOwn = Model.Sender == Model.TargetUserId; // или сравни с текущим пользователем
}

<div class="message message-appear @(isOwn ? "message-own" : "message-other")">
    <div class="message-header">
        <strong>@Model.Sender</strong>
        <small>@Model.Timestamp.ToString("HH:mm")</small>
    </div>
    <div class="message-content">@Model.Content</div>
</div>
