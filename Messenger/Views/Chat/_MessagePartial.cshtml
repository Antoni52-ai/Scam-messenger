@model Messenger.Models.Entity.ChatMessage

@{
    var currentUserName = User?.Identity?.Name ?? string.Empty;
    var senderName = Model.SenderName ?? Model.Sender;
    var isOwn = string.Equals(senderName, currentUserName, System.StringComparison.OrdinalIgnoreCase) ||
                string.Equals(Model.Sender, currentUserName, System.StringComparison.OrdinalIgnoreCase);
}

<div class="message message-appear @(isOwn ? "message-own" : "message-other")" data-message-id="@Model.Id">
    <div class="message-header">
        <strong>@senderName</strong>
        <small>@Model.Timestamp.ToString("HH:mm")</small>
    </div>
    <div class="message-content">@Model.Content</div>
</div>
