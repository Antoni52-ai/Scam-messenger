<div class="rooms-sidebar">
    <h3>Групповые чаты</h3>
    <button id="createRoomBtn" class="btn btn-primary">+ Создать</button>
    <ul id="roomsList" class="room-list">
        <!-- Список комнат -->
    </ul>
</div>

<!-- Модальное окно создания комнаты -->
<div id="createRoomModal" style="display:none;">
    <input type="text" id="roomNameInput" placeholder="Название комнаты" />
    <textarea id="roomDescInput" placeholder="Описание"></textarea>
    <button id="confirmCreateRoom">Создать</button>
    <button id="cancelCreateRoom">Отмена</button>
</div>