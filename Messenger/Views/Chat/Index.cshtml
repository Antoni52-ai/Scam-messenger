@model Messenger.Models.ViewModel.ChatViewModel
@{
    ViewData["Title"] = "Чат";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

<section class="chat-shell">
    <header class="app-header">
        <div class="app-header-left">
            <span class="app-logo">NOVA MESSENGER</span>
            <span class="app-subtitle">Защищенный канал общения команды</span>
        </div>
        <div class="app-header-right">
            <span id="connectionStatusDot" class="connection-dot" title="Статус соединения"></span>
            <span class="app-username">@User.Identity!.Name</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                <button type="submit" class="btn-logout">Выйти</button>
            </form>
        </div>
    </header>

    <div class="chat-container">
        <aside class="sidebar">
            <div class="sidebar-section">
                <div class="sidebar-head sidebar-head-split">
                    <h4>Комнаты (<span id="roomCount">0</span>)</h4>
                    <button id="openCreateRoomBtn" type="button" class="btn-create-room">Создать</button>
                </div>
                <ul id="roomList" class="room-list"></ul>
            </div>

            <div class="sidebar-section sidebar-section-users">
                <div class="sidebar-head">
                    <h4>Онлайн (<span id="onlineCount">0</span>)</h4>
                </div>
                <ul id="onlineUsers" class="user-list"></ul>
            </div>
        </aside>

        <main class="chat-area">
            <header class="chat-header">
                <h3 id="chatTitle">Общий чат</h3>
                <button id="backToPublicChat" style="display:none;">Вернуться в общий чат</button>
                <span id="typingIndicator" class="typing-indicator"></span>
            </header>

            <div id="messagesContainer" class="messages-container">
                @foreach (var msg in Model.RecentMessages)
                {
                    <partial name="_MessagePartial" model="msg" />
                }
            </div>

            <div class="chat-input">
                <textarea id="messageInput"
                          placeholder="Введите сообщение..."
                          rows="2"
                          maxlength="2000"></textarea>
                <button id="sendBtn" class="btn-send" aria-label="Отправить">➤</button>
            </div>
        </main>
    </div>

    <div id="createRoomModal" class="modal-backdrop" hidden>
        <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="createRoomTitle">
            <div class="modal-head">
                <h4 id="createRoomTitle">Создать комнату</h4>
                <button type="button" id="closeCreateRoomModal" class="btn-modal-close" aria-label="Закрыть">×</button>
            </div>

            <form id="createRoomForm" class="modal-form">
                <label for="roomNameInput">Название</label>
                <input id="roomNameInput" name="roomName" type="text" maxlength="80" required />

                <label for="roomDescriptionInput">Описание</label>
                <textarea id="roomDescriptionInput" name="roomDescription" rows="3" maxlength="300"></textarea>

                <div class="modal-actions">
                    <button type="submit" class="btn-send">Создать</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/chat.js" asp-append-version="true"></script>
    <script>
        window.chatConfig = {
            currentUserName: @Html.Raw(Json.Serialize(Model.CurrentUser)),
            currentUserId: @Html.Raw(Json.Serialize(Model.CurrentUserId)),
            targetUserId: @Html.Raw(Json.Serialize(ViewBag.TargetUserId)),
            targetUserName: null,
            activeRoomId: null
        };
    </script>
}
