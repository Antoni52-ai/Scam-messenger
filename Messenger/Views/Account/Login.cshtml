@model Messenger.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="auth-card">
    <h2 class="auth-title">Вход</h2>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="All" class="auth-errors"></div>

        <div class="auth-field">
            <label>Имя пользователя:</label>
            <input asp-for="Username" />
        </div>

        <div class="auth-field">
            <label>Пароль:</label>
            <input asp-for="Password" type="password" />
        </div>

        <button type="submit" class="btn-neon">Войти</button>
    </form>

    <p class="auth-footer">
        Нет аккаунта? <a asp-action="Register" class="neon-link">Зарегистрироваться</a>
    </p>
</div>
