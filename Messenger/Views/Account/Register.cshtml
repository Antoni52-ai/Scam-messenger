@model Messenger.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-card">
    <h2 class="auth-title">Регистрация</h2>

    <form asp-action="Register" method="post">
        <div asp-validation-summary="All" class="auth-errors"></div>

        <div class="auth-field">
            <label>Имя пользователя:</label>
            <input asp-for="Username" />
        </div>

        <div class="auth-field">
            <label>Email:</label>
            <input asp-for="Email" />
        </div>

        <div class="auth-field">
            <label>Пароль:</label>
            <input asp-for="Password" type="password" />
        </div>

        <button type="submit" class="btn-neon">Зарегистрироваться</button>
    </form>

    <p class="auth-footer">
        Уже есть аккаунт? <a asp-action="Login" class="neon-link">Войти</a>
    </p>
</div>
